    {
      "parameters": {
        "jsCode": "\nconst analysis = $input.first().json.text || $input.first().json.response || '';\nconst now = new Date().toISOString().split('T')[0];\nreturn [{ json: {\n  text: analysis,\n  slackMessage: `🎯 *ICP & Segmentation Analysis — ${now}*\\n\\n${analysis}`,\n  emailHtml: `<h2>ICP & Segmentation Analysis — ${now}</h2><div style=\"font-family: sans-serif; line-height: 1.6;\">${analysis.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>')}</div>`,\n  emailSubject: `ICP Analysis Report — ${now}`,\n  timestamp: now\n}}];\n"
      },
