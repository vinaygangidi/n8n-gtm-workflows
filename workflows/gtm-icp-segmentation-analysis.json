        "limit": 250,
        "filters": {}
      },
      "id": "41fe06f6-3204-4779-85ad-402d0355590b",
      "name": "Fetch Won Deals",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2,
      "position": [
        544,
        112
      ],
      "alwaysOutputData": true,
      "credentials": {
        "hubspotOAuth2Api": {
          "id": "JeOX6jr31U3kqrBr",
          "name": "HubSpot account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "\nconst deals = $input.all();\n\nconst enriched = deals.map((item, i) => {\n  const d = item.json.properties || item.json;\n  const created = new Date(d.createdate);\n  const closed = new Date(d.closedate);\n  const cycleDays = Math.round((closed - created) / (1000 * 60 * 60 * 24));\n\n  return `Deal ${i+1}: ${d.dealname || 'Unnamed'}\n  - ACV: $${Number(d.amount || 0).toLocaleString()}\n  - Sales Cycle: ${cycleDays} days\n  - Source: ${d.hs_analytics_source || 'N/A'}\n  - Pipeline: ${d.pipeline || 'N/A'}\n  - Close Date: ${d.closedate || 'N/A'}`;\n}).join('\\n\\n');\n\nconst amounts = deals.map(d => Number((d.json.properties || d.json).amount || 0));\nconst avgACV = amounts.reduce((a,b) => a+b, 0) / amounts.length;\n\nreturn [{ json: {\n  dealData: enriched,\n  dealCount: deals.length,\n  avgACV: Math.round(avgACV),\n  stats: `Total won deals: ${deals.length} | Avg ACV: $${Math.round(avgACV).toLocaleString()}`\n}}];\n"
      },
      "id": "14354f0c-e59e-46cb-b504-bd7be73ad2b6",
      "name": "Enrich & Format Deal Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        112
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "You are a RevOps analyst. Here is data from our last {{ $json.dealCount }} closed-won deals:\n\n{{ $json.dealData }}\n\nStats: {{ $json.stats }}\n\nIdentify the top firmographic and behavioural characteristics of our best customers, defined by highest ACV and shortest sales cycle.\n\nFor each characteristic, note how frequently it appears and its correlation with revenue impact. Flag any segments that appear often but have long cycles or low ACV.\n\nOutput as:\n1. **Executive Summary** — Who is our ideal customer in 2-3 sentences\n2. **Prioritised ICP Profile** — Ranked characteristics with frequency %, avg ACV, and avg cycle length\n3. **Recommended Scoring Weights** — Attribute weights for lead scoring (must total 100)\n4. **Anti-ICP Signals** — Segments to deprioritize\n5. **Actions** — 3 specific recommendations for SDRs, AEs, and marketing\n\nUse markdown formatting.",
        "messages": {
          "messageValues": [
            {
              "type": "systemMessage",
              "message": "You are a RevOps analyst specializing in ICP definition and market segmentation. Be quantitative and specific."
            }
          ]
        }
      },
      "id": "fe1a64f8-3a88-46bb-919a-be3ec02927c7",
      "name": "Analyze ICP Patterns",
